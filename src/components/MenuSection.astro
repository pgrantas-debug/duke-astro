<section id="menu" class="relative px-5 py-20 md:px-8 md:py-28">
  <div class="relative z-10 mx-auto max-w-4xl">
    <h2 class="font-display text-4xl leading-none text-cream md:text-6xl">
      <span data-i18n="es">LA CARTA</span><span data-i18n="en">THE MENU</span>
    </h2>
    <p class="mt-3 font-body text-sm text-cream/70">
      <span data-i18n="es">Toca</span><span data-i18n="en">Tap</span>
      <span class="duke-menu-hint-plus inline-flex h-5 w-5 items-center justify-center rounded-full text-xs align-middle mx-1">+</span>
      <span data-i18n="es">para añadir algo a tu pedido.</span>
      <span data-i18n="en">to add something to your order.</span>
    </p>

    <div class="duke-menu-controls mt-10" id="tabs-wrap">
      <div class="duke-menu-search search-wrapper">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5" stroke-linecap="round"></path>
        </svg>
        <input
          id="menu-search"
          type="text"
          class="duke-search-input search"
          placeholder="Buscar en la carta..."
          data-placeholder-es="Buscar en la carta..."
          data-placeholder-en="Search the menu..."
          aria-label="Search menu"
        />
      </div>
      <div class="duke-tabs-row flex flex-wrap gap-2" id="tabs">
      <button data-tab="all" class="duke-tab tab-btn tab-active" type="button">
        <span data-i18n="es">Todos</span><span data-i18n="en">All</span>
      </button>
      <button data-tab="burgers" class="duke-tab tab-btn" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10h16M3 14h18a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM6 10a6 4 0 0 1 12 0" stroke-linecap="round"/></svg>
        <span data-i18n="es">Hamburguesas</span><span data-i18n="en">Burgers</span>
      </button>
      <button data-tab="hotdogs" class="duke-tab tab-btn" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a3 3 0 0 1 3-3h12a3 3 0 0 1 0 6H6a3 3 0 0 1-3-3z" stroke-linecap="round"/></svg>
        Hot Dogs
      </button>
      <button data-tab="empanadas" class="duke-tab tab-btn" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12c0-4 3.5-8 8-8s8 4 8 8-4 4-8 4-8 0-8-4z" stroke-linecap="round"/></svg>
        Empanadas
      </button>
      <button data-tab="sandwiches" class="duke-tab tab-btn" type="button">
        <span data-i18n="es">Bocadillos</span><span data-i18n="en">Sandwiches</span>
      </button>
      <button data-tab="tapas" class="duke-tab tab-btn" type="button">
        <span data-i18n="es">Tapas</span><span data-i18n="en">Tapas</span>
      </button>
      <button data-tab="milanesas" class="duke-tab tab-btn" type="button">
        <span data-i18n="es">Milanesas</span><span data-i18n="en">Milanesas</span>
      </button>
      <button data-tab="drinks" class="duke-tab tab-btn" type="button">
        <span data-i18n="es">Bebidas</span><span data-i18n="en">Drinks</span>
      </button>
      </div>
    </div>

    <!-- Populated client-side by src/scripts/app.js: renders MENU data,
         respects the active language, and wires up the add-to-cart buttons. -->
    <div class="duke-menu-shell mt-10 p-5 md:p-8" id="menu-panels"></div>
  </div>
</section>
