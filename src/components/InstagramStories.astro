---
import { restaurant } from '../data/site.js';
import { GALLERY } from '../data/menu.js';
---
<section id="gallery" class="relative bg-ink px-5 py-20 md:px-8 md:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-6">
      <div>
        <span class="kicker">DUKE MOMENTS</span>
        <h2 class="mt-3 font-display text-4xl text-cream md:text-5xl">@DUKE.SABINILLAS</h2>
        <p class="mt-3 max-w-md font-body text-sm text-stone">
          <span data-i18n="es">Galería del local, platos reales y ambiente de Duke en Sabinillas.</span>
          <span data-i18n="en">Venue moments, real dishes and Duke atmosphere in Sabinillas.</span>
        </p>
      </div>

      <a href={restaurant.instagram} target="_blank" rel="noopener noreferrer" class="btn-ghost focus-ring">
        <span data-i18n="es">Síguenos en Instagram</span><span data-i18n="en">Follow on Instagram</span>
      </a>
    </div>

    <div class="ig-slider" id="ig-slider">
      <div class="ig-track" id="ig-track">
        {GALLERY.map((story) => (
          <a href={restaurant.instagram} target="_blank" rel="noopener noreferrer" class="duke-gallery-card ig-story-card focus-ring">
            <img src={story.img} alt={story.caption.es} loading="lazy" />
            <svg class="duke-gallery-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none" />
            </svg>
            <span class="duke-gallery-caption"><span data-i18n="es">{story.caption.es}</span><span data-i18n="en">{story.caption.en}</span></span>
          </a>
        ))}
      </div>
      <div class="ig-dots" id="ig-dots" aria-label="Instagram slider pagination">
        {GALLERY.map((_, idx) => (
          <button
            type="button"
            class={`ig-dot ${idx === 0 ? 'is-active' : ''}`}
            data-ig-dot={idx}
            aria-label={`Go to story ${idx + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>
